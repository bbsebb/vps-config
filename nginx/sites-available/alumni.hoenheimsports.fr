# alumni Frontend
server {
    listen 80;
    server_name alumni.hoenheimsports.fr;

    access_log /var/log/nginx/alumni.hoenheimsports.fr-http-access.log;
    error_log /var/log/nginx/alumni.hoenheimsports.fr-http-error.log;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}
